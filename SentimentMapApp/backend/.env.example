# Environment configuration for SentimentMap Backend
# Copy this file to .env and configure for your environment

# Database
DATABASE_URL=sqlite:///sentiment_data.db

# Image Storage Mode
IMAGE_STORAGE_MODE=local  # 'local' or 'cloud'

# Local Image Storage (Development)
IMAGES_PATH=../images

# Cloud Storage (Production) - Configure when deploying
CLOUD_BUCKET_NAME=
CLOUD_CDN_URL=
CLOUD_REGION=us-east-1

# Image Optimization
IMAGE_QUALITY=85

# Performance
ENABLE_CACHING=False
CACHE_TTL=3600

# Flask
FLASK_DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production

# Database Debug
SQL_DEBUG=False
